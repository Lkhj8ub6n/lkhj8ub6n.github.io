---
layout: nil
sitemap:
  exclude: 'yes'
---
<?xml version="1.0" encoding="UTF-8"?>
<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9">
{% for page in site.html_pages %}{% unless page.sitemap.exclude == 'yes' %}  <url>
    <loc>{{ page.url | replace:'index.html','' | absolute_url }}</loc>
    <changefreq>monthly</changefreq>
  </url>
{% endunless %}{% endfor %}{% for page in site.pages %}{% if page.url contains '.md' or page.url contains '.markdown' %}  <url>
    <loc>{{ page.url | replace:'index.html','' | replace:'.md','/' | replace:'.markdown','/' | absolute_url }}</loc>
    <changefreq>monthly</changefreq>
  </url>
{% endif %}{% endfor %}{% for post in site.posts %}  <url>
    <loc>{{ post.url | absolute_url }}</loc>
    <lastmod>{{ post.date | date_to_xmlschema }}</lastmod>
    <changefreq>monthly</changefreq>
  </url>
{% endfor %}</urlset>
